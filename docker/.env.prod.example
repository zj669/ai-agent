# ============================================================
# AI Agent Platform - 生产环境变量配置
# 复制此文件为 .env.prod 并填写真实值
# 警告: 禁止将 .env.prod 提交到版本库！
# ============================================================

# ── MySQL ──────────────────────────────────────────────────
PRIMARY_DB_USER=root
PRIMARY_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_ANOTHER_STRONG_PASSWORD

# ── MinIO ─────────────────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET_NAME=knowledge-files

# ── JWT（随机生成，建议 64+ 字符）──────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_AT_LEAST_64_CHARS_LONG_abc123

# ── 邮件 SMTP ─────────────────────────────────────────────
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password

# ── CORS（允许的前端域名，逗号分隔）───────────────────────
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── CSDN MCP（文章发布工具）────────────────────────────────
# 从浏览器 CSDN 登录态复制完整 Cookie header。必须保存在 .env.prod，不要提交。
CSDN_COOKIE=
# 可选：覆盖 CSDN 请求头；留空时 MCP server 使用 HAR 中捕获到的默认值。
CSDN_USER_AGENT=
CSDN_REFERER=https://mp.csdn.net/mp_blog/creation/editor?spm=1000.2115.3001.4503

# ── 前端构建 ─────────────────────────────────────────────
VITE_API_BASE_URL=/api

# ── 镜像标签（默认 latest，可指定版本如 v1.2.3）──────────────
IMAGE_TAG=latest

# ── 端口映射（默认，可根据服务器调整）──────────────────────
FRONTEND_PORT=80
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MILVUS_GRPC_PORT=19530
MILVUS_METRICS_PORT=9091
