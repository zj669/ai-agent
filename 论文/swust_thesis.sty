%% ===========================================================
%% swust_thesis.sty — 西南科技大学本科毕业论文样式包
%% 严格遵照《2026版撰写规范》逐条实现
%% 编译方式：XeLaTeX
%% ===========================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{swust_thesis}[2026/03/27 SWUST Thesis v4]

%% ============================================================
%% 宏包加载（注意：不使用 titletoc，改用手动 TOC 格式）
%% ============================================================
\RequirePackage{geometry}
\RequirePackage{fontspec}
\RequirePackage{xeCJK}
\RequirePackage{amsthm}         % 必须在 unicode-math 之前加载
\RequirePackage{unicode-math}   % 替代 amsmath/amssymb/mathtools，提供标准数学字体
\RequirePackage{fancyhdr}
\RequirePackage{titlesec}
\RequirePackage{graphicx}
\RequirePackage{booktabs,array,tabularx,multirow,threeparttable}
\RequirePackage{listings}
\RequirePackage{xcolor}
\RequirePackage{tikz}
\RequirePackage{caption}
\RequirePackage{enumitem}
\RequirePackage{indentfirst}
\RequirePackage{zhnumber}
\RequirePackage[titles]{tocloft}
\RequirePackage[super]{gbt7714}   %% 数字上标引用，符合GB/T 7714-2015
\RequirePackage{hyperref}

%% ============================================================
%% 字体配置
%% ============================================================
\setCJKmainfont[BoldFont=FandolSong-Bold, ItalicFont=FandolKai-Regular]{FandolSong-Regular}
\setCJKsansfont[BoldFont=FandolHei-Bold]{FandolHei-Regular}
\setCJKmonofont{Noto Sans Mono CJK SC}

\setCJKfamilyfont{zhsong}[BoldFont=FandolSong-Bold]{FandolSong-Regular}
\setCJKfamilyfont{zhhei}[BoldFont=FandolHei-Bold]{FandolHei-Regular}
\setCJKfamilyfont{zhkai}{FandolKai-Regular}
\renewcommand{\songti}{\CJKfamily{zhsong}}
\renewcommand{\heiti}{\CJKfamily{zhhei}}
\renewcommand{\kaishu}{\CJKfamily{zhkai}}

\setmainfont{TeX Gyre Termes}
\setsansfont{TeX Gyre Heros}
\setmathfont{TeX Gyre Termes Math}  % 数学字体匹配正文 Times

\newcommand{\swusttitle}[1]{\def\@swusttitle{#1}}
\newcommand{\swusttitleen}[1]{\def\@swusttitleen{#1}}
\swusttitle{毕业论文题目}
\swusttitleen{Thesis Title}

\newCJKfontfamily\swustheaderfont[
  BoldFont       = STXingkai,
  ItalicFont     = STXingkai,
  BoldItalicFont = STXingkai
]{STXingkai}
\newcommand{\swustheadtitle}{\zihao{5}\swustheaderfont\mdseries 西南科技大学本科生毕业论文（设计）}
\newcommand{\swustdoubleheadrule}{\hrule width\headwidth height 0.8pt\vskip 0.8pt\hrule width\headwidth height 3.2pt}

%% ============================================================
%% 页面设置（规范 §二(六)）
%% ============================================================
\geometry{
  a4paper,
  top=2.5cm, bottom=2.5cm, left=3.0cm, right=2.0cm,
  headheight=1.5cm,
  headsep=0.4cm,
  footskip=1.0cm,
}

%% ============================================================
%% 行距：固定值 22 磅
%% ============================================================
\linespread{1.391}\selectfont
\setlength{\parindent}{2em}
\setlength{\parskip}{0pt}
\setlength{\emergencystretch}{2em}

%% ============================================================
%% 页眉页脚（规范 §二(六)1/3）
%% ============================================================
\fancypagestyle{thesisplain}{%
  \fancyhf{}%
  \fancyhead[C]{\swustheadtitle}%
  \fancyfoot[C]{\zihao{5}\songti\thepage}%
  \renewcommand{\headrule}{\swustdoubleheadrule}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

\fancypagestyle{frontmatter}{%
  \fancyhf{}%
  \fancyhead[C]{\swustheadtitle}%
  \fancyfoot[C]{\zihao{5}\songti\thepage}%
  \renewcommand{\headrule}{\swustdoubleheadrule}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

\pagestyle{thesisplain}

\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyhead[C]{\swustheadtitle}%
  \fancyfoot[C]{\zihao{5}\songti\thepage}%
  \renewcommand{\headrule}{\swustdoubleheadrule}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\footrulewidth}{0pt}%
}

\fancypagestyle{empty}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \renewcommand{\headrule}{}%
}

%% ============================================================
%% 章节标题格式（规范 §二(五)）
%% ============================================================

\titleformat{\chapter}[block]
  {\centering\zihao{-2}\heiti}
  {第\,\thechapter\,章}
  {1em}
  {}
\titlespacing{\chapter}{0pt}{0.5\baselineskip}{0.5\baselineskip}

\titleformat{\section}[block]
  {\zihao{4}\heiti}
  {\thesection}
  {1em}
  {}
\titlespacing{\section}{0pt}{12pt}{6pt}

\titleformat{\subsection}[block]
  {\zihao{-4}\heiti}
  {\thesubsection}
  {1em}
  {}
\titlespacing{\subsection}{0pt}{6pt}{4pt}

\titleformat{\subsubsection}[block]
  {\zihao{5}\heiti}
  {\thesubsubsection}
  {1em}
  {}
\titlespacing{\subsubsection}{0pt}{0.25\baselineskip}{0.25\baselineskip}

\renewcommand{\thechapter}{\arabic{chapter}}
\renewcommand{\thesection}{\thechapter.\arabic{section}}
\renewcommand{\thesubsection}{\thesection.\arabic{subsection}}
\ctexset{chapter/number=\arabic{chapter}}

%% ============================================================
%% 目录格式（规范 §二(八)）用 tocloft
%% ============================================================

%% 目录标题
\renewcommand{\contentsname}{\centering\zihao{-2}\heiti 目\quad 录}
\setcounter{tocdepth}{2}
\setcounter{secnumdepth}{3}
\renewcommand{\cftdotsep}{1.2}

%% 章条目格式（小4号黑体）
\renewcommand{\cftchapfont}{\zihao{4}\heiti}
\renewcommand{\cftchappagefont}{\zihao{4}}
\renewcommand{\cftchapleader}{\cftdotfill{\cftdotsep}}
\setlength{\cftchapnumwidth}{5em}
\cftsetindents{chapter}{0em}{5em}

%% 节条目格式（小4号宋体）
\renewcommand{\cftsecfont}{\zihao{-4}\songti}
\renewcommand{\cftsecpagefont}{\zihao{-4}}
\renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}
\cftsetindents{section}{1.5em}{2.2em}

%% 小节条目格式（小4号宋体）
\renewcommand{\cftsubsecfont}{\zihao{-4}\songti}
\renewcommand{\cftsubsecpagefont}{\zihao{-4}}
\renewcommand{\cftsubsecleader}{\cftdotfill{\cftdotsep}}
\cftsetindents{subsection}{3.5em}{3em}

%% ============================================================
%% 摘要环境
%% ============================================================
\newcommand{\cnabstract}{%
  \cleardoublepage
  \pagestyle{frontmatter}
  \phantomsection
  \addcontentsline{toc}{chapter}{摘要}
  \begin{center}
    {\zihao{-2}\heiti 摘\quad 要}
  \end{center}
  \vspace{0.5cm}
  \zihao{-4}\songti
}
\newcommand{\cnkeywords}[1]{%
  \vspace{\baselineskip}\noindent{\zihao{-4}\heiti 关键词：}{\zihao{-4}\songti #1}
}

\newcommand{\enabstract}{%
  \cleardoublepage
  \pagestyle{frontmatter}
  \phantomsection
  \addcontentsline{toc}{chapter}{Abstract}
  \begin{center}{\zihao{-2}\bfseries Abstract}\end{center}
  \vspace{0.5cm}
  \zihao{-4}
}
\newcommand{\enkeywords}[1]{%
  \vspace{\baselineskip}\noindent{\zihao{-4}\textbf{Keywords: }}{\zihao{-4} #1}
}

\newenvironment{abstractzh}{%
  \cleardoublepage
  \pagestyle{frontmatter}
  \thispagestyle{frontmatter}
  \begin{center}
    {\heiti\zihao{-1}\@swusttitle}
  \end{center}
  \vspace{0.5\baselineskip}
  \songti\zihao{-4}
}{}

\newenvironment{abstracten}{%
  \cleardoublepage
  \pagestyle{frontmatter}
  \thispagestyle{frontmatter}
  \begin{center}
    {\bfseries\zihao{-1}\@swusttitleen}
  \end{center}
  \vspace{0.5\baselineskip}
  \rmfamily\zihao{-4}
}{}

\newcommand{\keywordszh}[1]{\par\vspace{1.0\baselineskip}\noindent{\heiti\zihao{-4} 关键词：}{\songti\zihao{-4} #1}}
\newcommand{\keywordsen}[1]{\par\vspace{1.0\baselineskip}\noindent{\bfseries\zihao{-4} Keywords: }{\rmfamily\zihao{-4} #1}}

%% ============================================================
%% 致谢环境
%% ============================================================
\newcommand{\acknowledgement}{%
  \cleardoublepage
  \pagestyle{thesisplain}
  \phantomsection
  \chapter*{\centering 致\hspace{2em}谢}
  \addcontentsline{toc}{chapter}{致谢}
  \setlength{\parindent}{2em}
  \zihao{-4}\songti
}

%% ============================================================
%% 参考文献标题
%% ============================================================
\renewcommand{\bibname}{\centering\zihao{-2}\heiti 参考文献}

%% ============================================================
%% 公式编号：(式 章号-公式号)  规范 §十五(二)
%% ============================================================
\numberwithin{equation}{chapter}
\renewcommand{\theequation}{\thechapter-\arabic{equation}}
%% 自定义方程标签样式
\let\oldlabel\label
\renewcommand{\label}[1]{%
  \oldlabel{#1}%
}

%% ============================================================
%% 图表题注
%% ============================================================
\numberwithin{figure}{chapter}
\numberwithin{table}{chapter}
\renewcommand{\thefigure}{\thechapter-\arabic{figure}}
\renewcommand{\thetable}{\thechapter-\arabic{table}}
\captionsetup{labelsep=quad, font={bf,small,stretch=1.0}, justification=centering, skip=6pt}
\captionsetup[figure]{name={图}, position=below}
\captionsetup[table]{name={表}, position=above}

%% 规范要求表内文字说明为5号宋体
\RequirePackage{etoolbox}
\AtBeginEnvironment{table}{\zihao{5}\songti}

%% ============================================================
%% 定理环境
%% ============================================================
\theoremstyle{plain}
\newtheorem{theorem}{定理}[chapter]
\newtheorem{lemma}[theorem]{引理}
\newtheorem{proposition}[theorem]{命题}
\newtheorem{corollary}[theorem]{推论}
\theoremstyle{definition}
\newtheorem{definition}{定义}[chapter]
\newtheorem{example}{例}[chapter]
\theoremstyle{remark}
\newtheorem{remark}{注}[chapter]

%% ============================================================
%% 代码样式（支持 Unicode 字符）
\renewcommand{\lstlistingname}{代码}
\makeatletter
\@addtoreset{lstlisting}{chapter}
\makeatother
\providecommand{\thelstlisting}{}
\renewcommand{\thelstlisting}{\thechapter-\arabic{lstlisting}}
%% ============================================================
%% 定义支持 CJK/Unicode 的等宽字体命令
\newfontfamily\codefont{Noto Sans Mono CJK SC}[Scale=0.85]
\definecolor{codebg}{HTML}{F8FAFC}
\definecolor{codeframe}{HTML}{D0D7DE}
\definecolor{codenumber}{HTML}{8C959F}
\definecolor{codekeyword}{HTML}{0B5CAD}
\definecolor{codestring}{HTML}{0A7F3F}
\definecolor{codecomment}{HTML}{6A737D}
\definecolor{codeemph}{HTML}{8250DF}
\lstset{
  basicstyle=\zihao{-5}\codefont,
  keywordstyle=\color{codekeyword}\bfseries,
  commentstyle=\color{codecomment}\itshape,
  stringstyle=\color{codestring},
  emphstyle=\color{codeemph},
  morekeywords={var,record,yield,Optional,Stream,Map,List,Set,Queue,HashMap,HashSet,ArrayList,CompletableFuture,Override,Transactional,Async},
  numbers=left,
  numberstyle=\tiny\color{codenumber}\codefont,
  stepnumber=1,
  numbersep=8pt,
  frame=single,
  framerule=0.4pt,
  framesep=5pt,
  xleftmargin=1.8em,
  xrightmargin=0.6em,
  rulecolor=\color{codeframe},
  backgroundcolor=\color{codebg},
  showstringspaces=false,
  breaklines=true,
  breakatwhitespace=true,
  postbreak=\mbox{\textcolor{codenumber}{$\hookrightarrow$}\space},
  columns=flexible,
  keepspaces=true,
  tabsize=4,
  captionpos=t,
  aboveskip=8pt,
  belowskip=8pt,
  literate=
    {ε}{{$\varepsilon$}}1
    {ζ}{{$\zeta$}}1
    {π}{{$\pi$}}1
    {Δ}{{$\Delta$}}1
    {∞}{{$\infty$}}1
    {≈}{{$\approx$}}1
    {²}{{$^2$}}1
    {³}{{$^3$}}1
    {→}{{$\to$}}1,
}

\lstdefinelanguage{yaml}{
  sensitive=false,
  morecomment=[l]{\#},
  morestring=[b]",
  morestring=[b]',
  morekeywords={true,false,null,services,image,container_name,ports,environment,volumes,depends_on,build,networks,restart}
}

\lstdefinestyle{java}{
  language=Java,
  morekeywords={var,record,yield,Optional,Stream,Map,List,Set,Queue,HashMap,HashSet,ArrayList,CompletableFuture},
}

\lstdefinestyle{bash}{
  language=bash,
  morekeywords={docker,docker-compose,mvn,npm,mysql,xelatex,bibtex},
}

\lstdefinestyle{sql}{
  language=SQL,
}

\lstdefinestyle{yaml}{
  language=yaml,
  morekeywords={services,image,container_name,ports,environment,volumes,depends_on,build,networks,restart},
}

\lstdefinestyle{matlab}{
  language=Matlab,
  basicstyle=\zihao{-5}\codefont,
  numbers=left, numberstyle=\tiny\color{codenumber}\codefont,
  backgroundcolor=\color{codebg},
  showstringspaces=false,
  keywordstyle=\color{codekeyword}\bfseries,
  commentstyle=\color{codecomment}\itshape,
  stringstyle=\color{codestring},
  breaklines=true, frame=single,
  rulecolor=\color{codeframe}, tabsize=4,
}

%% ============================================================
%% 超链接
%% ============================================================
\hypersetup{
  colorlinks=true, linkcolor=black, citecolor=black, urlcolor=black,
  bookmarks=true, pdfencoding=auto,
}

%% ============================================================
%% 引用格式
%% ============================================================
\newcommand{\upcite}[1]{\textsuperscript{\cite{#1}}}

%% ============================================================
%% 附录章命令（规范 §二(二十)）
%% ============================================================
\newcounter{appendixnum}
\renewcommand{\theappendixnum}{\Alph{appendixnum}}
\newcommand{\appendixchapter}[1]{%
  \cleardoublepage
  \stepcounter{appendixnum}%
  \phantomsection
  \addcontentsline{toc}{chapter}{附录\theappendixnum\quad #1}%
  \begin{center}{\zihao{-2}\heiti 附录\,\theappendixnum\quad #1}\end{center}
  \vspace{0.5cm}
}

\newcommand{\appendixsection}[1]{%
  \section*{附录\,\Alph{appendixnum}\quad #1}%
}

%% ============================================================
%% 便利命令
%% ============================================================
\newcommand{\abs}[1]{\left|#1\right|}
\newcommand{\norm}[1]{\left\|#1\right\|}
