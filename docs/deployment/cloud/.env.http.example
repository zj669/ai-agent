# 应用 profile
SPRING_PROFILES_ACTIVE=local
JAVA_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# Docker 网络名称
AI_AGENT_DOCKER_NETWORK=docker_ai-agent-network

# 后端数据库
PRIMARY_DB_HOST=ai-agent-mysql
PRIMARY_DB_PORT=3306
PRIMARY_DB_NAME=ai_agent
PRIMARY_DB_USER=root
PRIMARY_DB_PASSWORD=change_me

# Redis
REDIS_HOST=ai-agent-redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# MinIO
MINIO_ENDPOINT=http://ai-agent-minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=change_me
MINIO_BUCKET_NAME=knowledge-files

# Milvus
MILVUS_ENABLED=true
MILVUS_HOST=ai-agent-milvus
MILVUS_PORT=19530

# 安全
JWT_SECRET=replace_with_32_plus_chars_secret

# Embedding，可按现场覆盖
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_NUM_CTX=1024
EMBEDDING_API_KEY=
