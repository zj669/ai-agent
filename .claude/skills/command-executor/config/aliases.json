{
  "defaults": {
    "log_dir": ".business/{feature}/executelogs/",
    "report_dir": ".business/{feature}/",
    "cache_ttl_hours": 24,
    "max_cache_size": 100
  },
  "templates": {
    "maven-build": "mvn clean install",
    "maven-test": "mvn test",
    "maven-package": "mvn package",
    "maven-clean": "mvn clean",
    "gradle-build": "./gradlew build",
    "gradle-test": "./gradlew test",
    "npm-install": "npm install",
    "npm-run-dev": "npm run dev",
    "npm-run-build": "npm run build",
    "npm-run-test": "npm test",
    "yarn-install": "yarn install",
    "yarn-dev": "yarn dev",
    "yarn-build": "yarn build",
    "yarn-test": "yarn test",
    "docker-up": "docker-compose up",
    "docker-down": "docker-compose down",
    "docker-build": "docker-compose build",
    "docker-logs": "docker-compose logs",
    "git-status": "git status",
    "git-diff": "git diff",
    "git-log": "git log --oneline -10",
    "git-pull": "git pull",
    "python-run": "python {script}",
    "python-test": "python -m pytest",
    "java-compile": "javac {files}",
    "java-run": "java {class}",
    "ping-host": "ping {host}",
    "curl-get": "curl -X GET {url}",
    "curl-post": "curl -X POST -H \"Content-Type: application/json\" -d '{data}' {url}"
  },
  "shortcuts": {
    "mb": "maven-build",
    "mt": "maven-test",
    "nb": "npm-run-build",
    "nt": "npm-run-test",
    "du": "docker-up",
    "dd": "docker-down",
    "gs": "git-status",
    "gd": "git-diff"
  }
}