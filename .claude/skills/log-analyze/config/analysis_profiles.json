{
  "defaults": {
    "report_dir": ".business/{feature}/analysis/",
    "cache_ttl_hours": 24,
    "max_cache_size": 50,
    "context_lines": 15,
    "max_errors": 20
  },
  "analysis_profiles": {
    "maven": {
      "name": "Maven/Java Build Logs",
      "error_patterns": [
        "\\[ERROR\\]",
        "BUILD FAILURE",
        "compilation failure",
        "Compilation error",
        "test failure",
        "Test FAILED",
        "ERROR:",
        "Failure:",
        "Exception in thread"
      ],
      "warning_patterns": [
        "\\[WARNING\\]",
        "deprecated",
        "unchecked",
        "rawtypes"
      ],
      "success_patterns": [
        "BUILD SUCCESS",
        "\\[INFO\\] BUILD SUCCESS",
        "Tests run:.*Failures: 0",
        "All tests passed"
      ],
      "file_patterns": [
        ".*\\.java:\\d+:",
        "error:.*at line \\d+",
        "\\[ERROR\\].*\\.java\\[\\d+,\\d+\\]"
      ],
      "stack_trace_start": [
        "at ",
        "Caused by:",
        "Exception:"
      ],
      "stack_trace_end": [
        "\\[INFO\\]",
        "\\[DEBUG\\]",
        "Tests run:"
      ]
    },
    "npm": {
      "name": "NPM/Node.js Logs",
      "error_patterns": [
        "ERR!",
        "error\\s",
        "failed",
        "npm ERR!",
        "ERROR:",
        "Failed at the",
        "command failed"
      ],
      "warning_patterns": [
        "WARN",
        "warning",
        "deprecated"
      ],
      "success_patterns": [
        "audited",
        "found 0 vulnerabilities",
        "successfully",
        "All tests passed"
      ],
      "file_patterns": [
        "Error:.*at ",
        "at .*\\(.*\\.js:\\d+:\\d+\\)"
      ],
      "stack_trace_start": [
        "Error:",
        "at ",
        "TypeError:"
      ],
      "stack_trace_end": [
        "npm ",
        "\\[\\d+/\\d+\\]"
      ]
    },
    "docker": {
      "name": "Docker/Container Logs",
      "error_patterns": [
        "error",
        "failed",
        "Cannot connect",
        "connection refused",
        "permission denied",
        "no such file",
        "exit code \\d+",
        "ERROR:"
      ],
      "warning_patterns": [
        "WARN",
        "warning",
        "deprecated"
      ],
      "success_patterns": [
        "up-to-date",
        "Successfully built",
        "Successfully tagged",
        "Started",
        "Running"
      ],
      "file_patterns": [
        "failed to create.*",
        "unable to.*",
        "Error response from daemon"
      ],
      "stack_trace_start": [
        "Error:",
        "panic:",
        "goroutine"
      ],
      "stack_trace_end": [
        "---\\[ cut here \\]---",
        "INFO\\[\\d+\\]"
      ]
    },
    "generic": {
      "name": "Generic Error Logs",
      "error_patterns": [
        "ERROR:",
        "FATAL:",
        "Exception:",
        "Error:",
        "failure",
        "failed",
        "unable to",
        "cannot",
        "invalid"
      ],
      "warning_patterns": [
        "WARNING:",
        "WARN:",
        "warning",
        "deprecated"
      ],
      "success_patterns": [
        "SUCCESS:",
        "successfully",
        "completed successfully",
        "OK"
      ],
      "file_patterns": [
        "File:.*",
        "in .*\\.(py|java|js|ts|cpp|go):\\d+",
        "line \\d+"
      ],
      "stack_trace_start": [
        "Stack trace:",
        "Traceback",
        "Exception in",
        "Caused by:"
      ],
      "stack_trace_end": [
        "^\\s*$",
        "^---",
        "^\\[\\d+/\\d+/\\d+"
      ]
    }
  },
  "output_formats": {
    "brief": {
      "include": ["error_count", "error_types", "first_error"],
      "max_errors": 3
    },
    "detailed": {
      "include": ["all_errors", "stack_traces", "file_references", "suggestions"],
      "max_errors": 10
    },
    "full": {
      "include": ["all_errors", "full_context", "statistics", "patterns", "suggestions"],
      "max_errors": 20
    }
  },
  "suggestion_templates": {
    "compilation_error": "检查代码语法和类型，确保所有导入正确。",
    "test_failure": "查看失败的测试用例，检查断言和测试数据。",
    "dependency_error": "检查依赖版本和仓库配置，尝试清理本地仓库。",
    "connection_error": "检查网络连接和服务器状态，确认端口和权限。",
    "permission_error": "检查文件/目录权限，确保有足够的访问权限。",
    "memory_error": "检查内存设置，可能需要增加堆大小或优化代码。"
  }
}