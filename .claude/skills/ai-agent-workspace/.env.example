# AI Agent 平台运维数据占位符
# 真实值放在 .env 或批准的 secret store，不要提交 .env 文件

# Spring Boot
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=13306
MYSQL_DATABASE=ai_agent
MYSQL_USERNAME=<your-mysql-user>
MYSQL_PASSWORD=<your-mysql-password>

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>
REDIS_DATABASE=0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=<your-minio-access-key>
MINIO_SECRET_KEY=<your-minio-secret-key>
MINIO_BUCKET=ai-agent

# JWT
JWT_SECRET=<your-jwt-secret>
JWT_EXPIRATION_MS=86400000

# etcd (Milvus dependency)
ETCD_ENDPOINTS=localhost:2379

# Frontend
VITE_API_BASE_URL=http://localhost:8080

# Workspace paths (for scripts)
AI_AGENT_WORKSPACE_ROOT=/home/zj669/repo/ai-agent
SKILL_ROOT=.claude/skills/ai-agent-workspace
